# backend/.dockerignore

# Виртуальное окружение - исключаем полностью
.venv/
venv/
env/
ENV/

# Кэши Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Локальные файлы
.env
.env.*
!.env.example

# Системные файлы
.DS_Store
Thumbs.db

# Данные БД (если есть локально)
*.db
*.sqlite3

# Логи
logs/
*.log

# Временные файлы
*.tmp
*.temp