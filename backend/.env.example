# ============================================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ
# ============================================

# Название приложения (используется в API документации)
APP_NAME="Marketplace API"

# Режим отладки: true - подробные ошибки, false - продакшн режим
DEBUG=true

# Секретный ключ для JWT токенов (в продакшне должен быть длинным и случайным)
SECRET_KEY=your-super-secret-key-here-change-this-in-production

# Время жизни access токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=30


# ============================================
# НАСТРОЙКИ БАЗЫ ДАННЫХ (PostgreSQL)
# ============================================

# Основной URL для подключения к базе данных
# Формат: postgresql://user:password@host:port/database
# Для Docker Compose используйте: postgresql://postgres:postgres@postgres:5432/marketplace
# Для локальной разработки: postgresql://postgres:postgres@localhost:5432/marketplace
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/marketplace


# ============================================
# НАСТРОЙКИ ПУЛА СОЕДИНЕНИЙ
# ============================================

# Минимальный размер пула соединений
DB_POOL_SIZE=5

# Максимальное количество дополнительных соединений сверх пула
DB_MAX_OVERFLOW=10

# Проверять соединение перед использованием (рекомендуется true)
DB_POOL_PRE_PING=true

# Логировать SQL запросы (true для отладки, false для продакшна)
DB_ECHO=true

# Время в секундах, через которое соединение переиспользуется
DB_POOL_RECYCLE=3600


# ============================================
# ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ
# ============================================

# Хост базы данных (если нужно разделять)
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=marketplace

# CORS настройки (разрешённые источники)
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Настройки Redis (для будущего использования)
# REDIS_URL=redis://redis:6379/0